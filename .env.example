# Copy to .env and adjust as needed. Do NOT commit your real .env.
POSTGRES_USER=pi
POSTGRES_PASSWORD=change-me
POSTGRES_DB=process_intelligence

# Host ports
DB_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Auth (Story 5.2). Set a long random value in any non-local deployment.
JWT_SECRET=change-me-in-production
JWT_EXPIRES_MINUTES=1440

# AI / LLM (Epic 6). Leave AI_PROVIDER=none to run fully offline with
# deterministic heuristics. Set to "openai" or "anthropic" and provide the
# matching key to enable live AI data-linking suggestions.
AI_PROVIDER=none
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
